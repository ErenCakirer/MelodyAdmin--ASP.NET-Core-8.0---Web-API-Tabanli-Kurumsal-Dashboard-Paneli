@model  List<ProductWithCategoryViewModel>

@{
    ViewData["Title"] = "ProductListWithCategory";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}
<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Kategorileri ile Ürün Listesi</h4>
                <p class="card-description">

                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                              
                                <th>Kategorisi</th>
                                <th>Stok</th>

                                
                            </tr>
                        </thead>
                        <tbody>

                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <td>@count</td>
                                    <td>@item.ProductName</td>
                                    <td>@item.CategoryName</td>
                                    <td>@item.ProductStock</td> 
                                </tr>
                            }

                        </tbody>
                    </table>
                    <a href="/Product/CreateProduct/" class="btn btn-primary">Yeni Ürün Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>