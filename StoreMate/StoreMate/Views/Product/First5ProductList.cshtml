
@model List<Product>
@{
    ViewData["Title"] = "ProductList";
    Layout = "~/Views/Layout/Index.cshtml";
}
<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title"> İlk 5 Ürün Listesi</h4>
                <p class="card-description">

                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Fiyat</th>
                                <th>Kategorisi</th>
                                <th>Stok</th>

                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th>@item.ProductId</th>
                                    <td>@item.ProductName</td>
                                    <td>@item.ProductPrice TL</td>
                                    <td>@item.Category.CategoryName</td>
                                    <td>@item.ProductStock</td>

                                    <td><a href="/Product/DeleteProduct/@item.ProductId" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Product/UpdateProduct/@item.ProductId" class="btn btn-success">Güncelle</a></td>
                                </tr>
                            }

                        </tbody>
                    </table>
                    <a href="/Product/CreateProduct/" class="btn btn-primary">Yeni Ürün Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div>
