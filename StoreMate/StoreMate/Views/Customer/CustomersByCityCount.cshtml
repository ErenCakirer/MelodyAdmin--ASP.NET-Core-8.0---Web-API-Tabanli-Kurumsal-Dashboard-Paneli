
   @model  List<CustomerCityGroup>
@{
    ViewData["Title"] = "CustomersByCityCount";
    Layout = "~/Views/Layout/Index.cshtml";
}
<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Müşteri Şehir Listesi</h4>
                <p class="card-description">
                  
                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Şehir</th>
                                <th>Müşteri Sayısı</th>
                              
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in Model)
                            {
                                <tr>
                                    <th>@item.City</th>
                                    <td>@item.CustomerCount</td>
                                </tr>
                            }
                           
                        </tbody>
                    </table>
                    
                </div>
            </div>
        </div>
    </div>
</div>
