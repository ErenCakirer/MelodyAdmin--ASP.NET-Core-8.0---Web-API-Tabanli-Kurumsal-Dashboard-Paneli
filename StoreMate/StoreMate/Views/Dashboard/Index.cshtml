@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("_HeadDashboardCP")
<body>
    <div class="container-scroller">
        @await Component.InvokeAsync("_NavbarDashboardCP")
        <div class="container-fluid page-body-wrapper">
            @await Component.InvokeAsync("_ThemeSettingsDashboard")
            @await Component.InvokeAsync("_RigthSidebarDashboardCP")
            @await Component.InvokeAsync("_SidebarDashboardCP")

            <div class="main-panel">
                <div class="content-wrapper">
                    <div class="page-header">
                        <h3 class="page-title">Dashboard</h3>
                    </div>

                 
                    @await Component.InvokeAsync("_Card_StatisticsDashboardCP")

                    <div class="row">
                        <div class="col-12 grid-margin stretch-card">
                            @await Component.InvokeAsync("_ChartDashboardCP")
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 grid-margin stretch-card">
                            @await Component.InvokeAsync("_SalesStatusDashboardCP")
                        </div>
                        <div class="col-md-6 grid-margin stretch-card">
                            @await Component.InvokeAsync("_ActivityDashboardCP")
                        </div>
                    </div>

                
                    <div class="row">
                        <div class="col-md-5 grid-margin stretch-card">
                            @await Component.InvokeAsync("_DailySalesDashboardCP")
                        </div>
                        <div class="col-md-7 grid-margin stretch-card">
                            @await Component.InvokeAsync("_SalesDataDashboardcs")
                        </div>
                    </div>

                   
                    <div class="row">
                        <div class="col-md-7 grid-margin stretch-card">
                            @await Component.InvokeAsync("Last5MessagesCP")
                        </div>
                        <div class="col-md-5 grid-margin stretch-card">
                            @await Component.InvokeAsync("_ToDoDashboardCP")
                        </div>
                    </div>

                </div> 

                <footer class="footer">
                    <div class="d-sm-flex justify-content-center justify-content-sm-between">
                        <span class="text-muted text-center text-sm-left d-block d-sm-inline-block">Copyright © @DateTime.Now.Year</span>
                        <span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center"> <i class="far fa-heart text-danger"></i></span>
                    </div>
                </footer>
            </div> 
        </div> 
    </div> 

 
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/vendors/js/vendor.bundle.base.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/vendors/js/vendor.bundle.addons.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/js/off-canvas.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/js/hoverable-collapse.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/js/misc.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/js/settings.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/js/todolist.js"></script>
    <script src="~/Melody-Premium-Bootstrap-Admin-Dashboard-Template/js/dashboard.js"></script>
</body>
</html>