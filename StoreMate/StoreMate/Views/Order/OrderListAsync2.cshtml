@model List<Order>
@{
    ViewData["Title"] = "OrderListAsync2";
    Layout = "~/Views/Layout/Index.cshtml";
   
}
<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Asenkron Sipariş Listesi</h4>
                <p class="card-description">

                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Müşteri</th>
                                <th>Sipariş Adet</th>
                                <th>Birim Fiyat</th>
                                <th>Toplam Fiyat</th>
                                <th>Durum</th>
                                <th>Sil</th>
                              
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                            
                                <tr>
                                    <th>@item.OrderId</th>
                                    <td>@item.Product.ProductName </td>
                                    <td>@item.Customer.CustomerName @item.Customer.CustomerSurname </td>
                                    <td>@item.OrderCount </td>
                                    <td>@item.UnitPrice TL </td>
                                    <td>@item.TotalPrice TL </td>
                                    <td>@item.Status</td>



                                    <td><a href="/Order/DeleteOrder/@item.OrderId" class="btn btn-danger">Sil</a></td>
                                   
                                </tr>
                            }

                        </tbody>
                    </table>
                    <a href="/Order/CreateOrder/" class="btn btn-primary">Yeni Müşteri Ekle</a>
                </div>
            </div>
        </div>
    </div>
</div> 
